{
    "name": "auto-signal-bot",
    "version": "1.0.0",
    "description": "Automated signal scanner — TradingView chart analysis and sports match odds, delivered via Telegram",
    "type": "module",
    "scripts": {
        "start": "tsx src/charts/index.ts",
        "build": "tsc",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "analyze": "tsx src/charts/index.ts",
        "forex-backtest": "tsx src/charts/forex-backtest-runner.ts",
        "betting-backtest": "tsx src/betting/betting-backtest-runner.ts",
        "performance-report": "tsx src/charts/performance-report-runner.ts",
        "test-analyze": "tsx src/charts/test-analyze.ts",
        "backtest:setups": "tsx src/charts/setup-backtest-runner.ts",
        "backtest:smc": "tsx src/charts/smc-backtest-runner.ts",
        "preflight:fetch": "tsx src/scripts/preflight-fetch.ts",
        "setup:telegram-menu": "tsx src/scripts/setup-telegram-menu-v2.ts",
        "match-odds": "tsx src/betting/betting-index.ts",
        "fetch-matches-list": "tsx src/betting/fetch-matches-list-index.ts",
        "lottery": "tsx src/lottery/lottery-index.ts",
        "lottery-backfill": "tsx src/lottery/lottery-backfill-index.ts",
        "lottery-predict": "tsx src/lottery/lottery-predict-index.ts",
        "lottery-predict:mien-nam": "LOTTERY_PREDICT_REGION=mien-nam tsx src/lottery/lottery-predict-index.ts",
        "lottery-predict:mien-trung": "LOTTERY_PREDICT_REGION=mien-trung tsx src/lottery/lottery-predict-index.ts",
        "lottery-predict:mien-bac": "LOTTERY_PREDICT_REGION=mien-bac tsx src/lottery/lottery-predict-index.ts",
        "lottery-predict-resync": "tsx src/lottery/lottery-predict-resync-index.ts",
        "lottery-verify": "tsx src/lottery/lottery-verify-index.ts",
        "lottery-backtest": "tsx src/lottery/lottery-backtest-index.ts",
        "lottery-hit-rate-report": "tsx src/lottery/lottery-hit-rate-report-index.ts"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.108.2",
        "@types/ws": "^8.18.1",
        "pino": "^10.3.1",
        "playwright": "^1.49.0",
        "simple-statistics": "^7.9.3",
        "ws": "^8.21.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@vitest/coverage-v8": "^4.1.9",
        "pino-pretty": "^13.1.3",
        "tsx": "^4.19.0",
        "typescript": "^5.6.0",
        "vitest": "^4.1.9"
    }
}
