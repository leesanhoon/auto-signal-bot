# Trading / lottery runtime
CHART_SIGNAL_CONFIDENCE_THRESHOLD=70
# Bob Volman's method doesn't screen setups by a fixed R:R (TP is a measured-move
# projection from structure, not a preset ratio) - keep this low, only to reject
# negative/zero R:R from calculation errors, not to filter setup quality.
POSITION_MIN_RISK_REWARD_RATIO=0.5
PENDING_ORDER_EXPIRY_RUNS=2
# CHART_ENGINE_MODE: deterministic (default) | shadow (comparison only)
CHART_ENGINE_MODE=deterministic

# Chart heartbeat / run context
CHART_RUN_CONTEXT=
CHART_HEARTBEAT_USE_LATEST_CACHE=true
CHART_SEND_HEARTBEAT_OUTSIDE_CLOSE_WINDOW=true
CHART_SEND_HEARTBEAT_ON_MANUAL_RUN=true

# CHART_TIMEFRAME_MODE:
# - multi: quet D1/H4/M15 cung luc
# - single: chi quet timeframe duoc chon
# Production target hien tai: single + H4
# Local `.env` va GitHub Actions `vars` la 2 kenh config khac nhau;
# CI analyze se doc CHART_ENGINE_MODE / CHART_TIMEFRAME_MODE / CHART_PRIMARY_TIMEFRAME tu workflow vars.
CHART_TIMEFRAME_MODE=single
CHART_PRIMARY_TIMEFRAME=H4

# Betting AI (match-odds dùng OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
AI_TEXT_MODEL=your_ai_text_model_here
AI_TEXT_FALLBACK_MODEL=your_ai_text_fallback_model_here
AI_REASONING_EFFORT=low
BETTING_AI_ANALYZE_TIMEOUT_MS=75000
BETTING_AI_COMBINED_TIMEOUT_MS=240000

# Telegram bot và webhook
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret_here

# Betting / football odds
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BOOKMAKER=your_api_football_bookmaker_here
API_FOOTBALL_LEAGUE=1,39,2

# Supabase service-role credentials
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_service_role_key_here
GITHUB_OWNER=your_github_owner_here
GITHUB_REPO=your_github_repo_here
GITHUB_PAT=your_github_fine_grained_pat_here
GITHUB_REF=main

# MetaApi — nguồn dữ liệu OHLC cho deterministic engine (thay OANDA)
METAAPI_TOKEN=your_metaapi_token_here
METAAPI_ACCOUNT_ID=your_metaapi_account_id_here
# METAAPI_REGION=new-york       # bỏ qua để tự phát hiện qua provisioning API
# METAAPI_SYMBOL_SUFFIX=        # ví dụ "m" nếu broker đặt tên symbol kiểu EURUSDm

# Twelve Data — provider thay thế khi MetaApi/OANDA không truy cập được
# (nếu set, ưu tiên dùng thay MetaApi)
TWELVEDATA_API_KEY=your_twelvedata_api_key_here
# TWELVEDATA_RATE_LIMIT_RPM=7   # mặc định 7 (free plan giới hạn 8 credit/phút)
CHART_TRADING_SYSTEM = smc

# Binance USDS-M Futures — thực thi lệnh thật cho tín hiệu Volman (chỉ cặp crypto)
# BINANCE_LIVE_TRADING_ENABLED: kill-switch, mac dinh false. CHI set true khi da test ky.
BINANCE_API_KEY=your_binance_futures_api_key_here
BINANCE_API_SECRET=your_binance_futures_api_secret_here
BINANCE_LIVE_TRADING_ENABLED=false
BINANCE_LEVERAGE=5
BINANCE_MARGIN_TYPE=ISOLATED
BINANCE_RISK_PERCENT_PER_TRADE=1
# Neu set, risk moi lenh la so USDT co dinh nay (uu tien hon BINANCE_RISK_PERCENT_PER_TRADE)
# Phu hop von nho: vd von 100 USDT, risk co dinh 10 USDT/lenh khong doi theo balance
BINANCE_RISK_USD_PER_TRADE=10
# Test end-to-end voi testnet TRUOC khi live: doi thanh https://testnet.binancefuture.com (API key testnet rieng)
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
# BINANCE_RATE_LIMIT_RPM=300   # mac dinh 300 request/phut
# BINANCE_LIVE_TRADING_ENABLED_SMC: kill-switch RIENG cho he SMC, mac dinh false.
# Ca 2 switch (BINANCE_LIVE_TRADING_ENABLED va bien nay) deu phai true moi trade That cho SMC.
BINANCE_LIVE_TRADING_ENABLED_SMC=false
# BINANCE_LIVE_TRADING_ENABLED_VOLMAN: kill-switch RIENG cho he Bob Volman, mac dinh false.
# Ca 2 switch (BINANCE_LIVE_TRADING_ENABLED va bien nay) deu phai true moi trade That cho Volman.
BINANCE_LIVE_TRADING_ENABLED_VOLMAN=false

# Bat entry order theo dung orderType cua signal (LIMIT/STOP) thay vi luon MARKET.
# Mac dinh false — GIU false cho toi khi da verify tren testnet.
BINANCE_HONOR_ORDER_TYPE_SMC=false
BINANCE_HONOR_ORDER_TYPE_VOLMAN=false

# So phut toi da 1 lenh entry LIMIT/STOP duoc phep "working" truoc khi tu dong huy.
BINANCE_ENTRY_ORDER_EXPIRY_MINUTES=60

# Optional: MARK_PRICE hoac CONTRACT_PRICE cho lenh dieu kien (SL/TP/entry STOP).
# Neu khong set, dung mac dinh cua Binance (CONTRACT_PRICE).
BINANCE_WORKING_TYPE=
