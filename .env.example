# Trading / lottery runtime
CHART_SIGNAL_CONFIDENCE_THRESHOLD=70
PENDING_ORDER_EXPIRY_RUNS=2
# CHART_ENGINE_MODE: deterministic (default) | shadow (comparison only)
CHART_ENGINE_MODE=deterministic

# Chart heartbeat / run context
CHART_RUN_CONTEXT=
CHART_HEARTBEAT_USE_LATEST_CACHE=true
CHART_SEND_HEARTBEAT_OUTSIDE_CLOSE_WINDOW=true
CHART_SEND_HEARTBEAT_ON_MANUAL_RUN=true

# CHART_TIMEFRAME_MODE:
# - multi: quet D1/H4/M15 cung luc
# - single: chi quet timeframe duoc chon
# Production target hien tai: single + M15
# Local `.env` va GitHub Actions `vars` la 2 kenh config khac nhau;
# CI analyze se doc CHART_ENGINE_MODE / CHART_TIMEFRAME_MODE / CHART_PRIMARY_TIMEFRAME tu workflow vars.
CHART_TIMEFRAME_MODE=multi
CHART_PRIMARY_TIMEFRAME=M15

# Betting (out of scope for this task)
AI_REASONING_EFFORT=low
BETTING_AI_ANALYZE_TIMEOUT_MS=75000
BETTING_AI_COMBINED_TIMEOUT_MS=240000

# Telegram bot và webhook
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret_here

# Betting / football odds
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BOOKMAKER=your_api_football_bookmaker_here
API_FOOTBALL_LEAGUE=1,39,2

# Supabase service-role credentials
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_service_role_key_here
GITHUB_OWNER=your_github_owner_here
GITHUB_REPO=your_github_repo_here
GITHUB_PAT=your_github_fine_grained_pat_here
GITHUB_REF=main

# MetaApi — nguồn dữ liệu OHLC cho deterministic engine (thay OANDA)
METAAPI_TOKEN=your_metaapi_token_here
METAAPI_ACCOUNT_ID=your_metaapi_account_id_here
# METAAPI_REGION=new-york       # bỏ qua để tự phát hiện qua provisioning API
# METAAPI_SYMBOL_SUFFIX=        # ví dụ "m" nếu broker đặt tên symbol kiểu EURUSDm

# Twelve Data — provider thay thế khi MetaApi/OANDA không truy cập được
# (nếu set, ưu tiên dùng thay MetaApi)
TWELVEDATA_API_KEY=your_twelvedata_api_key_here
# TWELVEDATA_RATE_LIMIT_RPM=7   # mặc định 7 (free plan giới hạn 8 credit/phút)
